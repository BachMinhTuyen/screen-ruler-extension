{
	"manifest_version": 3,
	"name": "Screen Ruler",
	"version": "1.0.0",
	"description": "Measure the size and position of elements directly in the browser",
	"permissions": [
		"activeTab",
		"scripting",
		"storage"
	],
	"icons": {
		"16": "icons/icon16.png",
		"128": "icons/icon128.png"
	},
	"action": {
		"default_title": "Turn on the measuring scale",
		"default_icon": {
			"16": "icons/icon16.png",
			"128": "icons/icon128.png"
		}
	},
	"background": {
		"service_worker": "src/background.js"
	},
	"web_accessible_resources": [
		{
			"resources": [
				"icons/*.png"
			],
			"matches": [
				"<all_urls>"
			],
			"use_dynamic_url": true
		}
	]
}